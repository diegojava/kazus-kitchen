---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import hero from "../assets/images/catering-hero.jpg"; // pon tu banner aquí
import Sidebar from "../components/Sidebar.astro";
import ContactStrip from "../components/ContactStrip.astro";
import ContactResult from "../components/ContactResult.astro";
---

<BaseLayout title="Catering | Kazu's Kitchen – Chef Kazu Kumoto">
  <Fragment slot="sidebar">
    <Sidebar />
  </Fragment>
  <!-- Hero -->
  <section class="relative h-[220px] w-full md:h-[280px]">
    <Image
      src={hero}
      alt="Catering"
      class="absolute inset-0 h-full w-full object-cover"
      priority
    />
    <div class="absolute inset-0 bg-black/25"></div>
  </section>

  <!-- Body -->
  <section class="bg-white text-zinc-800">
    <div class="mx-auto max-w-5xl px-6 py-14 md:px-10 md:py-16">
      <!-- Title -->
      <h1
        class="text-center font-serif tracking-[0.18em] lg:text-7xl md:text-6xl sm:text-lg"
      >
        CATERING
      </h1>

      <p
        class="mt-6 text-center font-serif text-base tracking-[0.08em] text-zinc-700"
      >
        ¡TAMBIÉN LLEVAMOS LA COCINA DE KAZU A TUS EVENTOS!
      </p>

      <p
        class="mt-4 text-center font-serif text-lg tracking-[0.12em] text-zinc-700"
      >
        SOLICITA TU COTIZACIÓN
      </p>

      <!-- Lines left/right (como en la referencia) -->
      <div class="mt-8 flex items-center justify-center gap-6">
        <div class="hidden h-px w-40 bg-zinc-200 md:block"></div>
        <div class="h-px w-20 bg-zinc-200"></div>
        <div class="hidden h-px w-40 bg-zinc-200 md:block"></div>
      </div>

      <ContactResult
        name="success-msg"
        id="success-msg"
        variant="success"
        class="hidden"
      />
      <ContactResult
        name="error-msg"
        id="error-msg"
        variant="error"
        class="hidden"
      />

      <!-- Form -->
      <form class="mx-auto mt-12" name="catering" action="/api/contact" method="POST">
        <!-- Honeypot -->
        <p class="hidden">
          <label>
            Don’t fill this out: <input name="bot-field" />
          </label>
        </p>

        <input type="hidden" name="formType" value="catering" />

        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
          <input
            class="h-12 w-full border border-zinc-200 px-4 text-sm outline-none placeholder:text-zinc-400 focus:border-zinc-400"
            type="text"
            name="nombre"
            placeholder="Nombre"
            required
          />

          <input
            class="h-12 w-full border border-zinc-200 px-4 text-sm outline-none placeholder:text-zinc-400 focus:border-zinc-400"
            type="email"
            name="email"
            placeholder="Email"
            required
          />

          <input
            class="h-12 w-full border border-zinc-200 px-4 text-sm outline-none placeholder:text-zinc-400 focus:border-zinc-400"
            type="tel"
            name="telefono"
            placeholder="Teléfono"
          />

          <input
            class="h-12 w-full border border-zinc-200 px-4 text-sm outline-none placeholder:text-zinc-400 focus:border-zinc-400"
            type="text"
            name="asunto"
            placeholder="Asunto"
            required
          />
        </div>

        <textarea
          class="mt-6 min-h-[180px] w-full resize-y border border-zinc-200 px-4 py-3 text-sm outline-none placeholder:text-zinc-400 focus:border-zinc-400"
          name="mensaje"
          placeholder="Mensaje"
          required></textarea>

        <button
          type="submit"
          class="mt-10 w-full bg-black py-4 text-center text-xs font-semibold tracking-[0.3em] text-white hover:bg-zinc-900"
        >
          ENVIAR
        </button>
      </form>
    </div>
  </section>
  <ContactStrip />
</BaseLayout>

<script>
  import { set } from "astro:schema";

  const form = document.querySelector('form[name="catering"]');

  form!!.addEventListener("submit", async (e) => {
    e.preventDefault();

    const formData = new FormData(form);

    const body = new URLSearchParams();
    for (const [key, value] of formData.entries()) {
      body.append(key, value);
    }

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: {
          "Content-Type": "application/x-www-form-urlencoded",
        },
        body,
      });

      const data = await res.json();

      if (data.ok) {
        document.getElementById("success-msg")?.classList.remove("hidden");
        setTimeout(() => {
          document.getElementById("success-msg")?.classList.add("hidden");
        }, 5000);
        form.reset();
      } else {
        document.getElementById("error-msg")?.classList.remove("hidden");
        setTimeout(() => {
          document.getElementById("error-msg")?.classList.add("hidden");
        }, 5000);
      }
    } catch (err) {
      document.getElementById("error-msg")?.classList.remove("hidden");
      setTimeout(() => {
        document.getElementById("error-msg")?.classList.add("hidden");
      }, 5000);
    }
  });
</script>
